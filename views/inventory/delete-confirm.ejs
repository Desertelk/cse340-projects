<div class="form-container">
    <% if (title) { %>
    <h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<%- messages() %>
<form action="/inv/delete" method="post" id="deleteForm">

    <label for="inv_make">Make</label>
    <input type="text" name="inv_make" id="inv_make" required readonly value="<%= typeof inv_make != 'undefined' ? inv_make : '' %>">

    <label for="inv_model">Model</label>
    <input type="text" name="inv_model" id="inv_model" required readonly value="<%= typeof inv_model != 'undefined' ? inv_model : '' %>">

    <label for="inv_price">Price</label>
    <input type="number" name="inv_price" id="inv_price" required readonly value="<%= typeof inv_price != 'undefined' ? inv_price : '' %>">

    <label for="inv_year">Year</label>
    <input type="number" name="inv_year" id="inv_year" required readonly value="<%= typeof inv_year != 'undefined' ? inv_year : '' %>">

    <p>Are you sure you want to delete this vehicle?</p>

    <button type="submit">Delete Vehicle</button>

    <input type="hidden" name="inv_id" <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
    <% } %>>
</form>
</div>
