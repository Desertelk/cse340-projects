<header id="top-header">
    <span class="siteName">
        <a href="/" title="Return to home page">CSE</a>
    </span>
    <div id="tools">
        <% if(loggedin) { %>
            <a href="/account/" title="Go to account management">
                Welcome <%= accountData.account_firstname %>
            </a>
            |
            <a href="/account/logout" title="Log out">Logout</a>
        <% } else { %>
            <a title="Click to log in" href="/account/login">My Account</a>
        <% } %>
    </div>
</header>