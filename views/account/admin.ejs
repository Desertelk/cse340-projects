<% if (title) { %>
    <h1><%= title %></h1>
<% } %>

<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
    <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
<%  }) %>
</ul>
<% } %>

<div class="filter-container">
    <label for="filterFirst">First Name</label>
    <input type="text" id="filterFirst" placeholder="John">

    <label for="filterLast">Last Name</label>
    <input type="text" id="filterLast" placeholder="Smith">

    <label for="filterType">Account Type</label>
    <select id="filterType">
        <option value="">All</option>
        <option value="Client">Client</option>
        <option value="Employee">Employee</option>
        <option value="Admin">Admin</option>
    </select>
</div>


<div id="accountDisplay"></div>

<div class="save-button">
    <button id="saveAllRoles">Save Changes</button>
</div>

<script src="/js/admin.js"></script>