<% if (title) { %>
    <h1><%= title %></h1>
<% } %>

<%- messages() %>

<div class="login-container">
    <form action="/account/login" method="post" class="login-form" id="login-form">
        <label for="account_email">Email Address</label>
        <input type="email" name="account_email" id="account_email" required>
        <label for="account_password">Password</label>
        <span>Password must be at least 12 characters and contain at least: 1 number, 1 capital letter, and 1 special character</span>
        <input type="password" name="account_password" id="account_password" pattern="^(?=.*\d)(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required>

        <button type="submit">Login</button>
    </form>

    <p>Don't have an account? <a href="/account/register">Register here</a></p>
</div>



