<% if (title) { %>
    <h1><%= title %></h1>
<% } %>

<%- messages() %>

<div class="login-container">
    <form action="/account/login" method="post" class="login-form">
        <label for="account_email">Email Address</label>
        <input type="email" name="account_email" id="account_email" required>
        <label for="account_password">Password</label>
        <input type="password" name="account_password" id="account_password" required>

        <button type="submit">Login</button>
    </form>

    <p>Don't have an account? <a href="/account/register">Register here</a></p>
</div>



