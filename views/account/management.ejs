<% if(messages.notice) { %>
    <div class="notice"><%= messages.notice %></div>
<% } %>

<h2>Welcome <%= accountData.account_firstname %></h2>
<div class="account-links">
    <p>
        <a href="/account/update/<%= accountData.account_id %>">
            Update Account Information
        </a>
    </p>
    
    <% if(accountData.account_type === "Employee" || accountData.account_type === "Admin") { %>
        <h3>Inventory Management</h3>
        <p>
            <a href="/inv/">Manage Inventory</a>
        </p>
        <% } %>

    <% if(accountData.account_type === "Admin") { %>
        <h3>Admin Tools</h3>
        <p>
            <a href="/account/admin">Manage Users</a>
        </p>
    <% } %>
    </div>